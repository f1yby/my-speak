# Database - SQLite
DATABASE_URL="file:/app/data/my-speak.db"

# Server
PORT=3001
NODE_ENV=production

# CORS - Change to your domain
CORS_ORIGIN=https://yourdomain.com:8443

# Mediasoup - Public IP or domain for WebRTC (REQUIRED for production!)
# Without this, WebRTC will use 0.0.0.0 as ICE candidate address
# and browsers cannot connect to it.
MEDIASOUP_ANNOUNCED_ADDRESS=speak.f1yby.space