FROM node:20-alpine

WORKDIR /app

RUN apk add --no-cache sqlite sqlite-dev openssl openssl-dev libc6-compat python3 py3-pip make g++ linux-headers

COPY package*.json ./
COPY prisma ./prisma/

RUN npm ci

COPY . .

RUN npx prisma generate

RUN npm run build

RUN npm prune --production

EXPOSE 3001
EXPOSE 10000-10100/udp

CMD ["sh", "-c", "mkdir -p /app/data && npx prisma db push --skip-generate && node dist/index.js"]