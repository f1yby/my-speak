FROM node:20-alpine

WORKDIR /app

# Install SQLite and build dependencies
RUN apk add --no-cache sqlite sqlite-dev openssl openssl-dev libc6-compat python3 make g++

# Copy package.json
COPY package*.json ./

# Install dependencies
RUN npm install

# Copy prisma schema
COPY prisma ./prisma/

# Generate Prisma client
RUN npx prisma generate

# Create data directory for SQLite
RUN mkdir -p /app/data

# Expose port
EXPOSE 3001
EXPOSE 10000-10100/udp

# Start command
CMD ["npm", "run", "dev"]